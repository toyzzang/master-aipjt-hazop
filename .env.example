# Azure OpenAI를 실제로 사용할 때 필요한 값입니다.
# 값이 비어 있으면 PoC는 deterministic demo 생성기로 동작합니다.

AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_KEY
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure Portal 또는 Azure AI Foundry에서 만든 "배포 이름"입니다.
# 모델 이름(gpt-4o 등)이 아니라 deployment name을 넣어야 합니다.
AZURE_OPENAI_DEPLOYMENT=YOUR_DEPLOYMENT_NAME

# 사내 프록시 endpoint에서 SSL 인증서 오류가 날 때만 false로 둡니다.
# 운영에서는 false 대신 사내 CA 인증서를 컨테이너에 설치하는 것이 안전합니다.
AZURE_OPENAI_VERIFY_SSL=false

# KOSHA MSDS 사이트를 우선 조회합니다. 보통 수정하지 않아도 됩니다.
KOSHA_MSDS_BASE_URL=https://msds.kosha.or.kr

# 선택값입니다. KOSHA 조회 실패 시 일반 웹 검색 fallback으로 쓰고 싶을 때만 넣습니다.
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
BING_SEARCH_API_KEY=YOUR_BING_SEARCH_KEY

# 실시간 Agent 로그가 너무 빨리 지나가지 않도록 단계 사이에 두는 지연 시간입니다.
AGENT_LOG_DELAY_SECONDS=0.45

# Azure OpenAI 응답 대기 중 "생성 중" 로그를 몇 초마다 표시할지 정합니다.
AGENT_LLM_HEARTBEAT_SECONDS=2.0

# Docker Compose가 app 컨테이너에 기본 DATABASE_URL을 넣어주므로
# 일반적으로 직접 수정하지 않아도 됩니다.
# 로컬에서 uvicorn만 직접 실행하면서 Postgres를 쓰고 싶을 때 사용합니다.
DATABASE_URL=postgresql+psycopg://hazop:hazop@127.0.0.1:5432/hazop_poc
